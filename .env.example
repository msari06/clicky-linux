# Cloudflare Worker proxy URL — wrangler prints this after `wrangler deploy`.
# For a local worker dev server: http://localhost:8787
WORKER_URL=http://localhost:8787

# OpenAI model. Must support vision.
# Recommended: gpt-4o-mini (cheap, fast), gpt-4o (stronger), gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Push-to-text hotkey, pynput notation.
# Default: ctrl + alt + space. Modifier-only combos (just ctrl+alt) are not reliable.
# Examples: "<ctrl>+<alt>+<space>", "<ctrl>+<shift>+c", "<f12>"
HOTKEY=<ctrl>+<alt>+<space>

# --- Code mode (Claude Code subprocess) ---------------------------------------
# Code mode swaps the OpenAI-vision pipeline for the `claude` CLI running as a
# subprocess in the workspace below. Toggle vision/code at runtime from the
# input bar.

# Path to the `claude` binary. Leave as "claude" if it's on PATH.
CLAUDE_CODE_PATH=claude

# Default working directory for Code mode. You can override per-prompt by
# prefixing with @/path (e.g. `@~/dev/foo fix the lint errors`).
# Defaults to the Clicky repo so you can have Clicky hack on itself.
# CLAUDE_CODE_WORKSPACE=/home/you/dev/myproject

# Optional model alias for Code mode. Leave blank to use Claude Code's default.
# Examples: sonnet, opus, claude-sonnet-4-6
CLAUDE_CODE_MODEL=

# Hard cap on agent turns per prompt. 0 = no cap.
CLAUDE_CODE_MAX_TURNS=0
