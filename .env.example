# Cloudflare Worker proxy URL — wrangler prints this after `wrangler deploy`.
# For a local worker dev server: http://localhost:8787
WORKER_URL=http://localhost:8787

# OpenAI model. Must support vision.
# Recommended: gpt-4o-mini (cheap, fast), gpt-4o (stronger), gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Push-to-text hotkey, pynput notation.
# Default: ctrl + alt + space. Modifier-only combos (just ctrl+alt) are not reliable.
# Examples: "<ctrl>+<alt>+<space>", "<ctrl>+<shift>+c", "<f12>"
HOTKEY=<ctrl>+<alt>+<space>
